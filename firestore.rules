
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow get, list, create, update: if isOwner(userId);
      
      match /aiCorpus/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /auctions/{auctionId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;

      match /bids/{bidId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.bidderId == request.auth.uid;
      }
    }
  }
}
