
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user within the BidNiche marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "role", "createdAt"]
    },
    "AICorpusItem": {
      "title": "AICorpusItem",
      "description": "A strategic fragment stored in the user's private AI knowledge base.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "category": { "type": "string", "enum": ["preference", "fact", "risk_appetite", "technical_debt", "past_win"] },
        "content": { "type": "string" },
        "source": { "type": "string", "description": "Context where this insight was derived." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "category", "content", "createdAt"]
    },
    "Auction": {
      "title": "Auction",
      "description": "Represents an auction listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "currentHighestBid": { "type": "number" },
        "endTimestamp": { "type": "string", "format": "date-time" },
        "sellerId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "title", "description", "currentHighestBid", "endTimestamp", "sellerId", "status"]
    },
    "Bid": {
      "title": "Bid",
      "description": "Represents a bid.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "auctionId": { "type": "string" },
        "bidderId": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "auctionId", "bidderId", "amount", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/aiCorpus/{corpusItemId}": {
      "schema": "#/backend/entities/AICorpusItem",
      "description": "Private strategic knowledge base for the user's AI assistant."
    },
    "/auctions/{auctionId}": {
      "schema": "#/backend/entities/Auction",
      "description": "Public auction listings."
    },
    "/auctions/{auctionId}/bids/{bidId}": {
      "schema": "#/backend/entities/Bid",
      "description": "Bid history for auctions."
    }
  }
}
